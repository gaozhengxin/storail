# Local public-domain subgraph deployment config.
# Copy to packages/operator/public-domain-subgraph/.env.

GRAPH_DEPLOY_KEY=your-graph-studio-deploy-key
SUBGRAPH_ACCOUNT_ID=your-graph-studio-account-id
SUBGRAPH_SLUG=storail-arbitrum-sepolia
SUBGRAPH_QUERY_URL=https://api.studio.thegraph.com/query/YOUR_ACCOUNT/YOUR_PUBLIC_DOMAIN_SUBGRAPH/version/latest
