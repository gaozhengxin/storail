# Local testnet e2e config.
# Copy to scripts/e2e/.env when running pnpm e2e:arbitrum-sepolia locally.

PRIVATE_KEY=0xYOUR_TESTNET_FUNDED_PRIVATE_KEY
ARBITRUM_SEPOLIA_RPC_URL=https://your-arbitrum-sepolia-rpc.example
ARBITRUM_SEPOLIA_CHAIN_ID=421614
RELAY_WORKER_URL=https://your-relay-worker.example
SUBGRAPH_QUERY_URL=https://api.studio.thegraph.com/query/YOUR_ACCOUNT/YOUR_PUBLIC_DOMAIN_SUBGRAPH/version/latest
PAYMENT_DEMO_SUBGRAPH_QUERY_URL=https://api.studio.thegraph.com/query/YOUR_ACCOUNT/YOUR_PAYMENT_DEMO_SUBGRAPH/version/latest
